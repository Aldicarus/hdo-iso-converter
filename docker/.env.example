# HDO ISO Converter — Configuración de despliegue
# Copiar a .env y ajustar los valores según tu NAS.
#
# Para ver los pools ZFS disponibles: ssh admin@nas "ls -la /share/"

# Puerto web (default 8090 — el 8080 lo usa QTS)
HDO_PORT=8090

# Zona horaria
TZ=Europe/Madrid

# ── Rutas del NAS (QuTS hero ZFS) ─────────────────────────────
# Cada ruta debe existir antes de arrancar el contenedor.

# Carpeta con los ISOs UHD Blu-ray (read-only)
ISOS_PATH=/share/ZFS19_DATA/Movies/Apps/Torrent/Download/Movies

# Carpeta de salida para los MKVs finales
OUTPUT_PATH=/share/ZFS19_DATA/Movies/Apps/HDOTools/MKVs

# Carpeta temporal para MKVs intermedios (SSD recomendado)
TMP_PATH=/share/ZFS19_DATA/Movies/Apps/HDOTools/hdo-tmp

# Carpeta de configuración (sesiones JSON + cola)
CONFIG_PATH=/share/ZFS19_DATA/Movies/Apps/HDOTools/hdo-config

# Carpeta con RPUs CMv4.0 externos (Tab 3) — read-only, opcional
# Coloca aquí los .bin descargados de REC999 u otras fuentes.
# Si no quieres usar esta funcionalidad, déjalo comentado o apunta a un dir vacío.
CMV40_RPU_PATH=/share/ZFS19_DATA/Movies/Apps/HDOTools/cmv40_rpus
